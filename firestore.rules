rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles: Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Zones, Notifications, Queues: Publicly readable, admin only write
    match /zones/{zoneId} {
      allow read: if true;
      allow write: if false; // Only via Admin SDK/Console
    }
    
    match /notifications/{notifId} {
      allow read: if true;
      allow write: if false;
    }
    
    match /queues/{queueId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Crowd Reports: Anyone can create (even anonymous), but not modify/delete
    match /crowd_reports/{reportId} {
      allow create: if true; 
      allow read: if true;
      allow update, delete: if false;
    }
    
    // Analytics & Stats: Publicly readable, admin write
    match /stats/{statId} {
      allow read: if true;
      allow write: if false;
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
